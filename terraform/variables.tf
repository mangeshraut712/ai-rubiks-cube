variable "project_id" {
  description = "Google Cloud project ID"
  type        = string
}

variable "region" {
  description = "Google Cloud region"
  type        = string
  default     = "us-central1"
}

variable "service_name" {
  description = "Cloud Run service name"
  type        = string
  default     = "rubiks-tutor"
}

variable "image" {
  description = "Container image URI in Artifact Registry"
  type        = string
}
