{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "vite",
    "installCommand": "npm ci --prefix frontend",
    "buildCommand": "npm run build --prefix frontend",
    "outputDirectory": "frontend/dist",
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
