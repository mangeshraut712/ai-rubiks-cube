# Backend
PORT=8080
GEMINI_API_KEY=your_gemini_api_key
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# Optional voice tuning for Cubey
# Leave GEMINI_VOICE_NAME empty to use model default voice.
GEMINI_VOICE_NAME=
GEMINI_VOICE_LANG=en-US
# Optional streaming tuning for longer, less-truncated voice turns.
GEMINI_SILENCE_DURATION_MS=1800
GEMINI_MAX_OUTPUT_TOKENS=1536
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Demo mode - keep false for normal local usage.
# For judge mode, use contest/.env.judges.example (DEMO_MODE=true).
# If DEMO_MODE=true and GEMINI_API_KEY is missing, server uses local demo fallback.
DEMO_MODE=false

# Frontend (optional override — Vite dev proxy handles /ws automatically)
VITE_BACKEND_ORIGIN=http://localhost:8080
