# Gemini Rubik's Tutor - Environment Template
# Copy this to .env and fill in your API key

# Backend
PORT=8080
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Allow Cloud Run, Vercel previews, and common local frontend ports
CORS_ORIGIN=https://*.run.app,https://*.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Contest/Judge mode:
# true  -> enables demo-friendly behavior (works scanning virtual cubes)
# false -> normal live tutoring flow (expects physical cube)
DEMO_MODE=false

# Frontend connection
VITE_BACKEND_ORIGIN=http://localhost:8080
# Optional public hosted backend used by static frontend deploys
# VITE_PUBLIC_BACKEND_ORIGIN=https://gemini-rubiks-tutor-vnc62azkwq-uc.a.run.app

# Optional: JSON array of ICE server entries for production TURN/STUN config
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]

# Optional: on Cloud Run, redirect "/" to hosted frontend (for example Vercel)
FRONTEND_REDIRECT_URL=
